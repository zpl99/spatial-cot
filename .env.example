# Copy this file to ".env" and fill in your credentials.
#   cp .env.example .env
# The ".env" file is git-ignored and must never be committed.

# --- OpenAI API ---
# Required for GPT models (gpt-4o, gpt-5, ...) and for the
# text-embedding-3-small model used by the SCT graph retrieval (Spatial CoT+).
OPENAI_API_KEY=

# --- Amazon Bedrock (Claude models) ---
# Required only if you run Claude models (e.g.,
# us.anthropic.claude-haiku-4-5-20251001-v1:0) via AWS Bedrock.
# This is a Bedrock API key (bearer token); leave blank if not using Claude.
AWS_BEARER_TOKEN_BEDROCK=
# Optional: Bedrock region (defaults to us-east-1 if unset).
AWS_REGION=us-east-1

# --- Azure OpenAI (optional) ---
# Required only if you instantiate the engine with use_azure=True.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_ENDPOINT=
